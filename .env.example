# n8n webhook that receives membership form submissions, rejects duplicate phone
# numbers (409), generates a unique SM10-XXXXXX one-time 10% discount code, and
# stores the member + coupon in the ShopeMoon Members / ShopeMoon Membership
# Coupons data tables.
# Local dev: use the n8n TEST webhook URL so it hits the test listener.
# Production: omit this var to fall back to the production webhook URL baked into src/app/api/membership/route.ts,
# or set it explicitly to the same production URL.
MEMBERSHIP_WEBHOOK_URL=https://amirhesam.app.n8n.cloud/webhook-test/shopemoon-membership-v2

# n8n webhook that receives experience/review form submissions, generates a unique
# SM-XXXXXX coupon code, and stores the submission + coupon in the ShopeMoon
# Experience Coupons data table (for future checkout validation).
# Local dev: use the n8n TEST webhook URL so it hits the test listener.
# Production: omit this var to fall back to the production webhook URL baked into
# src/app/api/experience/route.ts, or set it explicitly to the same production URL.
EXPERIENCE_WEBHOOK_URL=https://amirhesam.app.n8n.cloud/webhook-test/shopemoon-experience

# Telegram bot used to notify the ShopeMoon team about new membership signups
# and experience/review submissions. Create a bot via @BotFather to get the
# token, then add the bot to your target chat/group/channel to get the chat ID
# (e.g. via https://api.telegram.org/bot<token>/getUpdates).
# If either var is missing, the app logs a warning in development and simply
# skips the Telegram notification — it never blocks or breaks form submission.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
